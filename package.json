{
  "name": "sparql-editor",
  "version": "0.7.1",
  "description": "Sparql Editor based on CodeMirror 6",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "concurrently \"tsup --watch\" \"http-server . -o /test/index.html -c-1\"",
    "build": "tsup",
    "release": "release-it"
  },
  "author": "Achraf Atauil",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.0.0",
    "http-server": "^14.0.0",
    "release-it": "^17.10.0",
    "tsup": "^8.5.1",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "codemirror": "^6.0.1",
    "codemirror-lang-sparql": "^2.1.0",
    "sparqljs": "^3.7.1"
  }
}
